{
    "name": "@kilu-control/sdk",
    "version": "0.2.1",
    "description": "Execution authority layer for AI agents — ALLOW / REQUIRE_CONFIRM / BLOCK policy gate before tool calls, browser actions, or agent executions",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "bun test",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "kilu",
        "agent",
        "authority",
        "execution",
        "policy",
        "mcp",
        "langgraph",
        "browser-use",
        "ai-safety",
        "sdk"
    ],
    "author": "KiLu Network",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/IkaRiche/kilu-sdk"
    },
    "homepage": "https://kilu.network",
    "devDependencies": {
        "@types/node": "^20.0.0",
        "bun-types": "^1.0.0",
        "tsup": "^8.0.1",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "@noble/ed25519": "^2.3.0",
        "@noble/hashes": "^2.0.1"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    }
}
